{
  "name": "book-club",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/client",
    "packages/server",
    "packages/shared"
  ],
  "scripts": {
    "build": "echo \"Build scripts will be added in Task 1.3+\"",
    "db:migrate": "npm run db:migrate --workspace @book-club/server",
    "db:smoke": "npm run db:smoke --workspace @book-club/server",
    "dev": "concurrently \"npm run dev --workspace @book-club/server\" \"npm run dev --workspace @book-club/client\"",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run test --workspace @book-club/server && npm run test --workspace @book-club/client"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.29.1"
  }
}
