{
  "name": "book-club",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "book-club",
      "version": "0.1.0",
      "workspaces": [
        "packages/client",
        "packages/server",
        "packages/shared"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@book-club/client": {
      "resolved": "packages/client",
      "link": true
    },
    "node_modules/@book-club/server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/@book-club/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/client": {
      "name": "@book-club/client",
      "version": "0.1.0"
    },
    "packages/server": {
      "name": "@book-club/server",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@book-club/shared",
      "version": "0.1.0"
    }
  }
}
